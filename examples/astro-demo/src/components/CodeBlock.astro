---
export interface Props {
  title: string;
  language: string;
}

const { title, language } = Astro.props;
---

<and-card variant="outline" class="block h-full overflow-hidden">
  <and-card-header>
    <div class="flex items-center justify-between gap-3">
      <and-card-title>{title}</and-card-title>
      <and-badge variant="secondary">{language}</and-badge>
    </div>
  </and-card-header>
  <and-card-content>
    <pre
      class="max-h-[560px] overflow-auto rounded-md bg-primary p-4 text-[0.82rem] leading-6 text-primary-foreground"><code><slot /></code></pre>
  </and-card-content>
</and-card>
