---
import { compileFlowmarkTemplate } from "../lib/flowmark";

export interface Props {
  context: Record<string, unknown>;
  template?: string;
}

const { context, template } = Astro.props;
const slotTemplate = Astro.slots.has("default")
  ? await Astro.slots.render("default")
  : "";
const { render } = await compileFlowmarkTemplate(template ?? slotTemplate);
const html = render(context);
---

<Fragment set:html={html} />
