---
import CodeBlock from "./CodeBlock.astro";
import type { GettingStartedContext } from "../data/types";

export interface Props {
  context: GettingStartedContext;
}

const { context } = Astro.props;
---

<section
  id="getting-started"
  class="page-frame py-16"
  aria-labelledby="getting-started-heading"
>
  <div class="text-center">
    <h2 id="getting-started-heading" class="text-3xl font-bold text-foreground">
      {context.title}
    </h2>
    <p class="mt-2 text-muted-foreground">{context.description}</p>
  </div>
  <div class="mt-10 grid gap-6 lg:grid-cols-3">
    {
      context.steps.map((step, index) => (
        <div class="grid gap-3">
          <div class="flex items-center gap-3">
            <span class="grid size-8 place-items-center rounded-full bg-primary text-sm font-bold text-primary-foreground">
              {index + 1}
            </span>
            <h3 class="text-lg font-bold text-foreground">{step.label}</h3>
          </div>
          <p class="text-muted-foreground">{step.description}</p>
          <CodeBlock
            title={step.label}
            language={step.label === "Install" ? "bash" : "astro"}
          >
            {step.code}
          </CodeBlock>
        </div>
      ))
    }
  </div>
</section>
