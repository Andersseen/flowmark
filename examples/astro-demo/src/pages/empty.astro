---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import { render } from "../generated/index.js";

const emptyContext = {
  title: "Empty State Demo",
  description: "This page demonstrates the @empty branch of a @for block.",
  featured: false,
  products: [],
};

const html = render(emptyContext);
const contextSource = JSON.stringify(emptyContext, null, 2);
---

<Layout title="Flowmark Empty State Demo">
  <main class="page-frame py-10">
    <section
      class="mb-8 flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <and-badge variant="outline">@empty branch</and-badge>
        <h1
          class="mt-4 text-3xl font-black tracking-normal text-foreground sm:text-4xl"
        >
          Empty State
        </h1>
        <p class="mt-3 max-w-2xl text-muted-foreground">
          The same compiled template renders the fallback branch when
          `ctx.products` is empty.
        </p>
      </div>
      <and-button href="/" variant="outline">Back to main demo</and-button>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <CodeBlock title="context" language="json">{contextSource}</CodeBlock>

      <and-card variant="outline" class="block h-full">
        <and-card-header>
          <div class="flex items-center justify-between gap-3">
            <and-card-title>Rendered output</and-card-title>
            <and-badge variant="secondary">HTML</and-badge>
          </div>
          <and-card-description>
            Generated by the same `src/templates/index.flow` file.
          </and-card-description>
        </and-card-header>
        <and-card-content>
          <div class="preview-surface flow-preview" set:html={html} />
        </and-card-content>
      </and-card>
    </section>
  </main>
</Layout>
