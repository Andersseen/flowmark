---
import Layout from "../layouts/Layout.astro";

import { site } from "../data";

const controlFlowExample = `@for (item of context.items) {
  <article>{{ item.title }}</article>
} @empty {
  <p>No items yet</p>
}`;

const eventsExample = `---
function save(event: Event) {
  console.log(event.type);
}
---

<button (click)="save($event)">Save</button>`;
---

<Layout title={site.title} description={site.description} siteUrl={site.url}>
  <section class="home-hero border-b border-border bg-card">
    <div
      class="page-frame grid gap-10 py-14 md:grid-cols-[0.95fr_1.05fr] md:items-center md:py-20"
    >
      <div class="grid gap-7">
        <p
          class="w-fit rounded-md border border-border bg-background px-3 py-1 text-sm font-bold uppercase tracking-normal text-muted-foreground"
        >
          Compiler playground
        </p>
        <div class="grid gap-4">
          <h1
            class="max-w-3xl text-4xl font-black tracking-normal text-foreground md:text-6xl"
          >
            Angular-style template DX, without Angular.
          </h1>
          <p class="max-w-2xl text-lg text-muted-foreground md:text-xl">
            Flowmark explores two focused compilers for Astro and server-first
            HTML: one for declarative control flow, and one for native browser
            events written as familiar template attributes.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href="/control-flow"
            class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-bold text-primary-foreground"
          >
            Control flow compiler
          </a>
          <a
            href="/events"
            class="inline-flex items-center rounded-md border border-border bg-background px-4 py-2 text-sm font-bold text-foreground"
          >
            Event compiler
          </a>
        </div>
        <dl class="home-stats grid gap-3 sm:grid-cols-3">
          <div>
            <dt>Output</dt>
            <dd>plain JS</dd>
          </div>
          <div>
            <dt>Runtime</dt>
            <dd>tiny helpers</dd>
          </div>
          <div>
            <dt>Host</dt>
            <dd>Astro first</dd>
          </div>
        </dl>
      </div>

      <div class="preview-surface flow-preview home-compiler-preview">
        <div class="compiler-preview-header">
          <span class="tag available">HTML compiler</span>
          <span class="tag sale">Events compiler</span>
        </div>

        <section aria-label="Control flow compiler preview">
          <h2>Control flow becomes render output</h2>
          <pre><code>{controlFlowExample}</code></pre>
        </section>

        <section aria-label="Events compiler preview">
          <h2>Events become native listeners</h2>
          <pre><code>{eventsExample}</code></pre>
        </section>

        <ol class="compiler-steps" aria-label="Flowmark compilation steps">
          <li>Author with familiar syntax</li>
          <li>Compile during Astro build</li>
          <li>Ship plain HTML and JavaScript</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="border-b border-border">
    <div class="page-frame grid gap-5 py-10 md:grid-cols-3">
      <article class="demo-card">
        <span class="tag available">1</span>
        <h2>Write less ceremony</h2>
        <p>
          Keep template logic near the markup: `@if` for branches and `(click)`
          for user intent.
        </p>
      </article>
      <article class="demo-card">
        <span class="tag sale">2</span>
        <h2>Compile before runtime</h2>
        <p>
          Flowmark works as build tooling, so pages receive generated functions
          and small runtime helpers.
        </p>
      </article>
      <article class="demo-card">
        <span class="tag">3</span>
        <h2>Stay framework-light</h2>
        <p>
          No components, router, signals, or hydration model are required for
          the compiler experiments.
        </p>
      </article>
    </div>
  </section>
</Layout>
