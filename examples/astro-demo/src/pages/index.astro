---
import Layout from "../layouts/Layout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import { render } from "../generated/index.js";
import { demoContext } from "../data/context.js";
import templateSource from "../templates/index.flow?raw";

const html = render(demoContext);

const generatedPreview = `import { escapeHtml, renderValue } from '@flowmark/runtime';

export function render(ctx) {
  let output = '';
  output += '<main><h1>';
  output += renderValue(ctx.title);
  output += '</h1>';

  if (ctx.featured) {
    output += '<span class="tag">Featured</span>';
  } else {
    output += '<span class="tag">Standard</span>';
  }

  const __items0 = Array.from((ctx.products) ?? []);
  if (__items0.length === 0) {
    output += '<p class="empty">No products found.</p>';
  } else {
    for (const product of __items0) {
      const __switch1 = product.status;
      switch (__switch1) {
        case 'available':
          output += '<span class="tag available">In stock</span>';
          break;
        case 'sale':
          output += '<span class="tag sale">On sale</span>';
          break;
        default:
          output += '<span class="tag unavailable">Unavailable</span>';
      }
    }
  }

  return output;
}`;
---

<Layout title="Flowmark Demo">
  <header class="hero-panel">
    <div
      class="page-frame grid gap-8 py-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end"
    >
      <div class="max-w-3xl">
        <and-badge variant="outline">Rust compiler + tiny JS runtime</and-badge>
        <h1
          class="mt-5 text-4xl font-black tracking-normal text-foreground sm:text-5xl"
        >
          Flowmark
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
          HTML-like templates with Angular-inspired control flow compiled into a
          plain JavaScript render function.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <and-button href="/empty" variant="default"
            >View empty state</and-button
          >
          <and-button
            href="https://github.com/andersseen/flowmark"
            target="_blank"
            variant="outline"
          >
            GitHub
          </and-button>
        </div>
      </div>

      <and-card variant="elevated" padded class="block">
        <div class="grid gap-4">
          <div>
            <p class="text-sm font-semibold text-muted-foreground">
              Current scope
            </p>
            <p class="mt-1 text-2xl font-bold text-foreground">
              @if, @for, @switch
            </p>
          </div>
          <div class="grid grid-cols-3 gap-2 text-sm">
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Escaped</p>
              <p class="text-muted-foreground">interpolation</p>
            </div>
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">Array.from</p>
              <p class="text-muted-foreground">iterables</p>
            </div>
            <div class="rounded-md border border-border p-3">
              <p class="font-bold">ESM</p>
              <p class="text-muted-foreground">output</p>
            </div>
          </div>
        </div>
      </and-card>
    </div>
  </header>

  <main class="page-frame py-10">
    <section class="grid gap-6 lg:grid-cols-2">
      <CodeBlock title="src/templates/index.flow" language="flow">
        {templateSource}
      </CodeBlock>

      <and-card variant="outline" class="block h-full">
        <and-card-header>
          <div class="flex items-center justify-between gap-3">
            <and-card-title>Rendered output</and-card-title>
            <and-badge variant="secondary">HTML</and-badge>
          </div>
          <and-card-description>
            Produced by the generated JavaScript render function.
          </and-card-description>
        </and-card-header>
        <and-card-content>
          <div class="preview-surface flow-preview" set:html={html} />
        </and-card-content>
      </and-card>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <and-card variant="outline" padded class="block">
        <div class="grid gap-5">
          <div>
            <and-badge variant="secondary">Compiler contract</and-badge>
            <h2 class="mt-4 text-2xl font-bold text-foreground">
              Small on purpose
            </h2>
            <p class="mt-3 text-muted-foreground">
              Flowmark does not ship components, hydration, directives, or a
              VDOM. It compiles trusted template source into a render function
              and lets the host app decide how to use the HTML.
            </p>
          </div>
          <div class="grid gap-3 text-sm">
            <div class="rounded-md border border-border p-4">
              <p class="font-semibold">Template source is trusted code</p>
              <p class="mt-1 text-muted-foreground">
                Expressions are emitted as JavaScript. Context values are
                escaped when interpolated.
              </p>
            </div>
            <div class="rounded-md border border-border p-4">
              <p class="font-semibold">`track` is reserved syntax</p>
              <p class="mt-1 text-muted-foreground">
                It is parsed today, but string rendering has no DOM diffing step
                where keys would matter.
              </p>
            </div>
          </div>
        </div>
      </and-card>

      <CodeBlock title="generated render function" language="js">
        {generatedPreview}
      </CodeBlock>
    </section>
  </main>
</Layout>
