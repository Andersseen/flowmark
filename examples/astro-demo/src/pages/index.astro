---
import Layout from "../layouts/Layout.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import GettingStarted from "../components/GettingStarted.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import LiveDemo from "../components/LiveDemo.astro";
import SyntaxShowcase from "../components/SyntaxShowcase.astro";

import { featuresContext } from "../data/features";
import { footerContext } from "../data/footer";
import { gettingStartedContext } from "../data/gettingStarted";
import { heroContext } from "../data/hero";
import { site } from "../data/site";
import { syntaxContext } from "../data/syntaxExamples";
---

<Layout title={site.title} description={site.description} siteUrl={site.url}>
  <Hero context={heroContext} />
  <Features context={featuresContext} />
  <SyntaxShowcase context={syntaxContext} />
  <HowItWorks />
  <LiveDemo />
  <GettingStarted context={gettingStartedContext} />
  <Footer context={footerContext} />
</Layout>
