---
import Layout from "../layouts/Layout.astro";

import { site } from "../data";
---

<Layout title={site.title} description={site.description} siteUrl={site.url}>
  <section class="border-b border-border bg-card">
    <div
      class="page-frame grid gap-8 py-16 md:grid-cols-[1.05fr_0.95fr] md:items-center md:py-24"
    >
      <div class="grid gap-6">
        <p
          class="text-sm font-bold uppercase tracking-normal text-muted-foreground"
        >
          Flowmark demo
        </p>
        <div class="grid gap-4">
          <h1
            class="text-4xl font-black tracking-normal text-foreground md:text-6xl"
          >
            Flowmark
          </h1>
          <p class="max-w-2xl text-lg text-muted-foreground md:text-xl">
            A small compiler playground for HTML control flow and separate
            Angular-style DOM event bindings.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href="/control-flow"
            class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-bold text-primary-foreground"
          >
            Control flow compiler
          </a>
          <a
            href="/events"
            class="inline-flex items-center rounded-md border border-border bg-background px-4 py-2 text-sm font-bold text-foreground"
          >
            Event compiler
          </a>
        </div>
      </div>

      <div class="preview-surface flow-preview">
        <main>
          <h2>Two compilers, one Astro demo</h2>
          <article>
            <span class="tag available">HTML</span>
            <h3>@if, @for, @switch and interpolation</h3>
            <p>Flowmark turns template control flow into render functions.</p>
          </article>
          <article>
            <span class="tag sale">Events</span>
            <h3>(click), $event, $el and literal args</h3>
            <p>
              The event compiler extracts client-safe handlers from Astro
              frontmatter.
            </p>
          </article>
        </main>
      </div>
    </div>
  </section>
</Layout>
