{
  "name": "flowmark",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm run build:rust && pnpm run build:runtime",
    "build:rust": "cargo build --workspace",
    "build:runtime": "pnpm --filter @flowmark/runtime build",
    "test": "pnpm run test:rust",
    "test:rust": "cargo test --workspace",
    "format": "cargo fmt --all"
  }
}
